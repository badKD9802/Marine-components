########################################
# OpenAI API 연결 설정
########################################

# ⭐ 여기에 실제 OpenAI API 키를 입력하세요
OPENAI_API_KEY=your-openai-api-key-here

# 모델명 (OpenAI 모델 선택)
# gpt-4o (최신, 강력함)
# gpt-4-turbo (빠르고 강력함)
# gpt-3.5-turbo (빠르고 저렴)
OPENAI_MODEL=gpt-4o

# 선택 사항: Custom endpoint (예: Azure OpenAI, vLLM 등)
# OPENAI_BASE_URL=http://your-custom-endpoint:8000/v1

# 선택 사항
MAX_ITERATIONS=10
TEMPERATURE=0.7
MAX_TOKENS=2048
